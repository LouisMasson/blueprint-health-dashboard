SUPABASE_DB_PASSWORD=your_supabase_db_password
OPENROUTER_API_KEY=your_openrouter_api_key

# Optional overrides
MODEL_1=anthropic/claude-sonnet-4-6
MODEL_2=x-ai/grok-3
MODEL_3=openai/gpt-4.5-turbo
MODEL_JUDGE=anthropic/claude-sonnet-4-6

# Optional: deployment URL (used as HTTP-Referer for OpenRouter)
APP_URL=http://localhost:8501

# dbt paths (adjust to your mount points)
DBT_PROJECT_DIR=/dbt
DBT_PROFILES_DIR=/dbt-profiles
DBT_BIN=/usr/local/bin/dbt
VENV_PYTHON=/usr/local/bin/python3
