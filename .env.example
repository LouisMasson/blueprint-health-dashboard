SUPABASE_DB_PASSWORD=your_supabase_db_password
OPENROUTER_API_KEY=your_openrouter_api_key

# Optional overrides
MODEL_1=anthropic/claude-sonnet-4-6
MODEL_2=x-ai/grok-3
MODEL_3=openai/gpt-4.5-turbo
MODEL_JUDGE=anthropic/claude-sonnet-4-6

# dbt paths (adjust if mounting volume)
DBT_PROJECT_DIR=/root/Projects/data-platform/dbt
DBT_PROFILES_DIR=/root/.dbt
DBT_BIN=/root/.venv-data-platform/bin/dbt
VENV_PYTHON=/root/.venv-data-platform/bin/python3
